# ─── Server ───
PORT=5000
NODE_ENV=development

# ─── MongoDB ───
MONGO_URI=mongodb://127.0.0.1:27017/hershild

# ─── JWT Secrets (replace with strong random strings) ───
ACCESS_TOKEN_SECRET=change_me_access_secret_hershild_2026
REFRESH_TOKEN_SECRET=change_me_refresh_secret_hershild_2026
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ─── OTP ───
OTP_EXPIRY_MINUTES=10

# ─── Frontend URL (CORS) ───
CLIENT_URL=http://localhost:3000
